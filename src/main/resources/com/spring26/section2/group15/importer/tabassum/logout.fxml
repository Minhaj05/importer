<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group15.importer.tabassum.logoutcontroller">
   <children>
      <Label fx:id="LogoutLBL" layoutX="221.0" layoutY="34.0" text="Logout" textFill="#1e942b">
         <font>
            <Font name="Berlin Sans FB Demi Bold" size="31.0" />
         </font>
      </Label>
      <Label layoutX="218.0" layoutY="138.0" prefHeight="14.0" prefWidth="136.0" text="Are You Sure?">
         <font>
            <Font name="Bauhaus 93" size="16.0" />
         </font>
      </Label>
      <Button layoutX="181.0" layoutY="188.0" mnemonicParsing="false" onAction="#yesButton" text="YES">
         <font>
            <Font name="Bodoni MT" size="12.0" />
         </font>
      </Button>
      <Button layoutX="305.0" layoutY="187.0" mnemonicParsing="false" onAction="#NoButton" text="NO">
         <font>
            <Font name="Bodoni MT" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
